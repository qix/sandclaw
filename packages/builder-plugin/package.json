{
  "name": "@sandclaw/builder-plugin",
  "version": "0.1.0",
  "description": "Sandclaw Builder plugin — Docker-based code builds via Confidante with human approval",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build-docker": "docker build -t builder-plugin docker/",
    "run": "tsx scripts/run-build.ts"
  },
  "dependencies": {
    "@sandclaw/gatekeeper-plugin-api": "*",
    "@sandclaw/muteworker-plugin-api": "*",
    "@sandclaw/confidante-plugin-api": "*",
    "@sandclaw/confidante-util": "*",
    "@sandclaw/ui": "*",
    "cac": "^7.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "*",
    "typescript": "*"
  }
}
