#!/usr/bin/env bash
set -eo pipefail
set -x

tmux new-session -d -s sandclaw-dev -c "$PWD" \; \
  set-option -p @name "gatekeeper" \; \
  send-keys "./tsx-watch gatekeeper.ts" Enter \; \
  split-window -v -c "$PWD" \; \
  set-option -p @name "muteworker" \; \
  send-keys "./tsx-watch muteworker.ts" Enter \; \
  split-window -v -c "$PWD" \; \
  set-option -p @name "confidante" \; \
  send-keys "./tsx-watch confidante.ts" Enter \; \
  set-option -g mouse on \; \
  set-option -g pane-border-status top \; \
  set-option -g pane-border-format " [ #[bold]#{@name}#[nobold] ] #{pane_title} "

exec tmux attach-session -t sandclaw-dev
