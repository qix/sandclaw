#!/usr/bin/env bash
set -eo pipefail
set -x

SESSION="sandclaw-dev"

if [[ "${1:-}" == "restart" ]]; then
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux kill-session -t "$SESSION"
  fi
fi

if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux new-session -d -s "$SESSION" -n services -c "$PWD" \; \
    set-option -p @name "chat" \; \
    send-keys "sleep 2 && ./chat" Enter \; \
    split-window -h -l 60% -c "$PWD" \; \
    set-option -p @name "gatekeeper" \; \
    send-keys "./gatekeeper --watch" Enter \; \
    split-window -v -c "$PWD" \; \
    set-option -p @name "muteworker" \; \
    send-keys "./muteworker --watch worker" Enter \; \
    split-window -v -c "$PWD" \; \
    set-option -p @name "confidante" \; \
    send-keys "./confidante --watch worker" Enter \; \
    select-layout -t "$SESSION:services" main-vertical \; \
    set-option -g mouse on \; \
    set-option -g pane-border-status top \; \
    set-option -g pane-border-format " [ #[bold]#{@name}#[nobold] ] #{pane_title} "
fi

exec tmux attach-session -t "$SESSION"
