{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "push": true,
    "requireCleanWorkingDir": true
  },
  "npm": false,
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "hooks": {
    "after:bump": "node scripts/fix-star-deps.mjs && npm run build"
  },
  "plugins": {
    "@release-it-plugins/workspaces": {
      "workspaces": ["packages/*"],
      "publish": true,
      "skipChecks": true
    }
  }
}
